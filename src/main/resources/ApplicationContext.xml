<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
       http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- Beans -->
    <bean id="myBean" class="com.example.demo.GreetingService"/>
    <bean id="smsService" class="com.example.loose.SMSService"/>
    <bean id="emailService" class="com.example.loose.EmailService"/>

    <bean id="userService" class="com.example.loose.UserService">
        <constructor-arg ref="smsService"/>
        <property name="emailService" ref="emailService"/>
    </bean>

</beans>